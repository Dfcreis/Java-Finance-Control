CREATE DATABASE financas;

USE financas;

CREATE TABLE gastos (
    id INT AUTO_INCREMENT PRIMARY KEY,
    descricao VARCHAR(100),
    valor DOUBLE,
    data DATE,
    categoria VARCHAR(50)
);

CREATE TABLE lucros (
    id INT AUTO_INCREMENT PRIMARY KEY,
    descricao VARCHAR(100),
    valor DOUBLE,
    data DATE,
    fonte VARCHAR(50)
);